/*
 * Behavior Definition — ZSOMGMT_I_SalesOrder (Interface / BO layer)
 *
 * managed    — RAP framework handles all CRUD persistence (INSERT/UPDATE/DELETE
 *              into zsomgmt_d_so_hdr / zsomgmt_d_so_itm automatically).
 * with draft — enables draft-based editing: users can pause and resume
 *              edits; draft rows are stored in zsomgmt_d_so_d_h / _d_i.
 * strict (2) — recommended strict mode for new development in S/4H 2022+.
 *
 * Activation sequence in ADT Eclipse:
 *   1. Activate DB tables (all four) first.
 *   2. Activate interface CDS views.
 *   3. Activate THIS behavior definition.
 *   4. Activate consumption CDS views.
 *   5. Activate projection BDEF.
 *   6. Activate behavior implementation class.
 *   7. Activate metadata extensions.
 *   8. Activate service definition and create service binding.
 */
managed implementation in class zbp_somgmt_i_salesorder unique;
strict ( 2 );
with draft;

/* ═══════════════════════════════════════════════════════════════════
   ROOT ENTITY — Sales Order Header
   ═══════════════════════════════════════════════════════════════════ */
define behavior for ZSOMGMT_I_SalesOrder alias SalesOrder
  persistent table zsomgmt_d_so_hdr
  draft table     zsomgmt_d_so_d_h
  lock master total etag LastChangedAt
  authorization master ( instance )
  etag master LastChangedAt
{
  /* ── Field controls ──────────────────────────────────────────── */
  field ( readonly )
    SalesOrderId,             // set by determination on CREATE
    OverallStatus,            // set by workflow actions only
    GrossAmount,              // computed by determination
    NetAmount,                // computed by determination
    TaxAmount,                // computed by determination
    CustomerName,             // derived from CustomerId lookup
    CreatedBy,
    CreatedAt,
    LastChangedBy,
    LastChangedAt;

  field ( mandatory )
    CustomerId,
    OrderDate,
    Currency;

  /* ── Standard CRUD operations ────────────────────────────────── */
  create;
  update;
  delete;

  // ── Draft actions (auto-generated by framework) ───────────────
  draft action Edit;
  draft action Activate optimized;
  draft action Discard;
  draft action Resume;

  // ── Draft determine action: run validations before Activate ───
  draft determine action Prepare
  {
    validation validateCustomer;
    validation validateDates;
    validation validateCurrency;
  }

  // ── Business Actions ──────────────────────────────────────────
  action ( instances ) submitForApproval result [1] $self;
  action ( instances ) approveOrder      result [1] $self;
  action ( instances ) rejectOrder
    parameter ZSOMGMT_A_RejectParam
    result    [1] $self;

  // ── Determinations ────────────────────────────────────────────
  determination setInitialStatus
    on modify { create; }

  determination recalculateHeaderAmounts
    on modify { delete; }

  // ── Validations (also run in draft determine action Prepare) ───
  validation validateCustomer
    on save { create; update; field CustomerId; }

  validation validateDates
    on save { create; update; field DeliveryDate; field OrderDate; }

  validation validateCurrency
    on save { create; update; field Currency; }

  // ── Composition: child items ──────────────────────────────────
  association _Item { create; with draft; }

  // ── Field-to-DB mapping ───────────────────────────────────────
  mapping for zsomgmt_d_so_hdr corresponding
  {
    SalesOrderId   = salesorderid;
    Description    = description;
    CustomerId     = customerid;
    CustomerName   = customername;
    OrderDate      = orderdate;
    DeliveryDate   = deliverydate;
    OverallStatus  = overallstatus;
    Currency       = currency;
    GrossAmount    = grossamount;
    NetAmount      = netamount;
    TaxAmount      = taxamount;
    CreatedBy      = createdby;
    CreatedAt      = createdat;
    LastChangedBy  = lastchangedby;
    LastChangedAt  = lastchangedat;
  }
}

/* ═══════════════════════════════════════════════════════════════════
   CHILD ENTITY — Sales Order Item
   ═══════════════════════════════════════════════════════════════════ */
define behavior for ZSOMGMT_I_SalesOrderItem alias SalesOrderItem
  persistent table zsomgmt_d_so_itm
  draft table     zsomgmt_d_so_d_i
  lock dependent   by _SalesOrder
  authorization dependent by _SalesOrder
  etag dependent   by _SalesOrder
{
  /* ── Field controls ──────────────────────────────────────────── */
  field ( readonly )
    SalesOrderId,             // inherited from parent
    NetAmount;                // computed by determination

  field ( mandatory )
    ProductId,
    Quantity,
    UnitPrice,
    Currency;

  // ── Standard operations (create is via parent association) ────
  update;
  delete;

  // ── Determination: calculate item net amount ──────────────────
  determination calculateItemNetAmount
    on modify { create; update ( field Quantity, field UnitPrice ); }

  // ── Validations ───────────────────────────────────────────────
  validation validateQuantity
    on save { create; update; field Quantity; }

  validation validateItemProduct
    on save { create; update; field ProductId; }

  // ── Back-navigation association ───────────────────────────────
  association _SalesOrder { with draft; }

  // ── Field-to-DB mapping ───────────────────────────────────────
  mapping for zsomgmt_d_so_itm corresponding
  {
    SalesOrderId       = salesorderid;
    ItemNumber         = itemnumber;
    ProductId          = productid;
    ProductDescription = productdescription;
    Quantity           = quantity;
    QuantityUnit       = uom;
    Currency           = currency;
    UnitPrice          = unitprice;
    NetAmount          = netamount;
    ItemStatus         = itemstatus;
  }
}
