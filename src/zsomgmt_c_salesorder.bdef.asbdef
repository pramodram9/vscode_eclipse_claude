/*
 * Behavior Projection — ZSOMGMT_C_SalesOrder (Consumption layer)
 *
 * projection  — delegates all operations to the interface BDEF.
 * use draft   — enables draft handling on the projection layer.
 * strict ( 2) — strict mode.
 *
 * Only operations, actions, and associations that are explicitly declared
 * with ````use```` are visible to OData consumers and Fiori Elements apps.
 * All others remain internal to the BO interface layer.
 */
projection;
strict ( 2 );
use draft;

/* ═══════════════════════════════════════════════════════════════════
   ROOT PROJECTION — Sales Order Header
   ═══════════════════════════════════════════════════════════════════ */
define behavior for ZSOMGMT_C_SalesOrder alias SalesOrder
{
  /* ── CRUD ────────────────────────────────────────────────────── */
  use create;
  use update;
  use delete;

  /* ── Draft lifecycle actions ─────────────────────────────────── */
  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  /* ── Business actions exposed to the UI ─────────────────────── */
  use action submitForApproval;
  use action approveOrder;
  use action rejectOrder;

  /* ── Composition child ───────────────────────────────────────── */
  use association _Item { create; with draft; }
}

/* ═══════════════════════════════════════════════════════════════════
   CHILD PROJECTION — Sales Order Item
   ═══════════════════════════════════════════════════════════════════ */
define behavior for ZSOMGMT_C_SalesOrderItem alias SalesOrderItem
{
  use update;
  use delete;

  use association _SalesOrder { with draft; }
}