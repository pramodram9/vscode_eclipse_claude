/*
 * Behavior Projection — ZLVTRK_C_Leave (Consumption layer)
 *
 * projection  — delegates all operations to the interface BDEF.
 * use draft   — enables draft handling on the projection layer.
 * strict (2)  — strict mode for ABAP Cloud.
 *
 * Only operations explicitly declared with `use` are visible to
 * OData consumers and Fiori Elements apps.
 */
projection;
strict ( 2 );
use draft;

define behavior for ZLVTRK_C_Leave alias Leave
{
  /* ── CRUD ────────────────────────────────────────────────────── */
  use create;
  use update;
  use delete;

  /* ── Draft lifecycle actions ─────────────────────────────────── */
  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;
}
